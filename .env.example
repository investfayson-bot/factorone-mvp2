# NFe.io — preencha em .env.local (não commitar segredos)
# Chave pode ser só no servidor (recomendado) ou NEXT_PUBLIC_* para builds que precisem.
NFEIO_API_KEY=
NEXT_PUBLIC_NFEIO_API_KEY=
NFEIO_COMPANY_ID=

# Resend — envio de PDF por e-mail
RESEND_API_KEY=
RESEND_FROM=noreply@seudominio.com

# OCR / extração inteligente de comprovantes e extratos
OPENROUTER_API_KEY=

# Supabase server-side
SUPABASE_SERVICE_ROLE_KEY=
